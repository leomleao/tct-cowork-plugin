{
  "name": "tct-writer",
  "display_name": "TCT Quote Writer",
  "version": "1.0.0",
  "description": "Generates formal SAP/ERP change request quotes for The Config Team. Fetches a TRS ticket, guides a structured discussion, then produces and fills a Word document using the standard Quote template.",
  "author": {
    "name": "Leonardo Leao"
  },
  "commands": [
    "./commands/"
  ],
  "mcpServers": {
    "trs-mcp": {
      "command": "node",
      "args": [
        "C:\\Dev\\trs-mcp\\build\\index.js"
      ],
      "env": {
        "TRS_USER_ID": "your-user-id",
        "TRS_USE_UI_AUTOMATION": "1"
      }
    },
    "word": {
      "command": "uvx",
      "args": [
        "--from",
        "word-mcp-live",
        "word_mcp_server.exe"
      ],
      "env": {
        "MCP_AUTHOR": "Leonardo Leao",
        "MCP_AUTHOR_INITIALS": "LL"
      }
    }
  }
}
