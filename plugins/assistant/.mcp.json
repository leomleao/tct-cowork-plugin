{
  "mcpServers": {
    "trs-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "github:leomleao/trs-mcp"
      ],
      "env": {
        "TRS_USER_ID": "your-user-id",
        "TRS_USE_UI_AUTOMATION": "1"
      }
    },
    "word": {
      "command": "uvx",
      "args": [
        "--from",
        "word-mcp-live",
        "word_mcp_server.exe"
      ],
      "env": {
        "MCP_AUTHOR": "The Config Team",
        "MCP_AUTHOR_INITIALS": "TCT"
      }
    }
  }
}