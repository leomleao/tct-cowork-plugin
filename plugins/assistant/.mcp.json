{
  "mcpServers": {
    "trs-mcp": {
      "command": "node",
      "args": [
        "C:\\Dev\\trs-mcp\\build\\index.js"
      ],
      "env": {
        "TRS_USER_ID": "your-user-id",
        "TRS_USE_UI_AUTOMATION": "1"
